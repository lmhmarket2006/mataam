# SQLite database file used by Prisma (path is relative to prisma/schema location).
DATABASE_URL="file:./dev.db"

# Digits-only country code + number for customer WhatsApp checkout links (wa.me).
NEXT_PUBLIC_WHATSAPP_NUMBER="966548599988"

# Secret for signing admin session cookies; use a long random string (32+ chars) in production.
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-characters"
